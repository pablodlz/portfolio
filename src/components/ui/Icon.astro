---
import { ICON_PATHS, type IconName } from '../../lib/icons';

interface Props {
  name: IconName;
  size?: number;
  class?: string;
}

const { name, size = 20, class: className } = Astro.props;
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  <path d={ICON_PATHS[name]}></path>
</svg>
