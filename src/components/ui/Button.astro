---
import Icon from './Icon.astro';
import type { IconName } from '../../lib/icons';

interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'ghost' | 'cta';
  icon?: IconName;
  external?: boolean;
  /** força download do href (ex.: currículo PDF) */
  download?: boolean;
  class?: string;
  /** atributos data-* extras (ex.: mailto ofuscado) */
  [key: `data-${string}`]: string | undefined;
}

const {
  href,
  variant = 'primary',
  icon,
  external = false,
  download = false,
  class: className,
  ...rest
} = Astro.props;
const externalAttrs = external ? { target: '_blank', rel: 'noopener noreferrer' } : {};
const downloadAttrs = download ? { download: true } : {};
---

<a class:list={['btn', `btn--${variant}`, className]} {href} {...externalAttrs} {...downloadAttrs} {...rest}>
  {icon && <Icon name={icon} size={18} />}
  <slot />
</a>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 12px 20px;
    border-radius: var(--radius-md);
    font-weight: 500;
    font-size: var(--fs-small);
    line-height: 1;
    cursor: pointer;
    text-decoration: none;
    transition:
      background-color var(--dur-2) var(--ease),
      border-color var(--dur-2) var(--ease),
      color var(--dur-2) var(--ease),
      transform var(--dur-1) var(--ease);
  }
  .btn:hover {
    text-decoration: none;
    transform: translateY(-1px);
  }

  .btn--primary {
    background: var(--accent);
    color: var(--on-accent);
  }
  .btn--primary:hover {
    background: var(--accent-hover);
    color: var(--on-accent);
  }

  .btn--secondary {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border-strong);
  }
  .btn--secondary:hover {
    color: var(--text);
    border-color: var(--text-3);
    background: var(--bg-raised);
  }

  .btn--ghost {
    background: transparent;
    color: var(--text-2);
    padding-inline: var(--space-3);
  }
  .btn--ghost:hover {
    color: var(--text);
    background: var(--bg-raised-2);
  }

  /* CTA premium: primário + shimmer periódico varrendo o botão */
  .btn--cta {
    position: relative;
    overflow: hidden;
    background: var(--accent);
    color: var(--on-accent);
    box-shadow: 0 0 0 0 var(--accent-soft);
    animation: cta-glow 3.2s var(--ease) infinite;
  }
  .btn--cta:hover {
    background: var(--accent-hover);
    color: var(--on-accent);
  }
  .btn--cta::after {
    content: '';
    position: absolute;
    inset: -40% auto;
    width: 36%;
    transform: translateX(-220%) skewX(-18deg);
    background: linear-gradient(
      100deg,
      transparent,
      rgba(255, 255, 255, 0.45),
      transparent
    );
    animation: cta-shimmer 3.2s var(--ease) infinite;
  }
  @keyframes cta-shimmer {
    0%,
    55% {
      transform: translateX(-220%) skewX(-18deg);
    }
    85%,
    100% {
      transform: translateX(420%) skewX(-18deg);
    }
  }
  @keyframes cta-glow {
    0%,
    55%,
    100% {
      box-shadow: 0 0 0 0 var(--accent-soft);
    }
    72% {
      box-shadow: 0 0 24px 2px var(--accent-soft);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .btn--cta,
    .btn--cta::after {
      animation: none;
    }
  }
</style>
