---
/** Janela de terminal (Portline): 3 dots, corpo mono, cursor opcional. */
interface Props {
  title?: string;
  ariaLabel?: string;
  class?: string;
}
const { title = 'bash — pablodlz', ariaLabel, class: className } = Astro.props;
---

<figure class:list={['terminal', className]} aria-label={ariaLabel}>
  <figcaption class="terminal-bar">
    <span class="terminal-dots" aria-hidden="true"><i></i><i></i><i></i></span>
    <span class="terminal-title">{title}</span>
  </figcaption>
  <div class="terminal-body">
    <slot />
  </div>
</figure>

<style>
  .terminal {
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    font-size: var(--fs-small);
  }
  .terminal-bar {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: 10px 14px;
    border-bottom: 1px solid var(--border);
    background: var(--bg-raised-2);
  }
  .terminal-dots {
    display: inline-flex;
    gap: 6px;
  }
  .terminal-dots i {
    width: 10px;
    height: 10px;
    border-radius: var(--radius-pill);
    background: var(--border-strong);
  }
  /* v3: chrome monocromático + um toque de acento (paleta única) */
  .terminal-dots i:first-child {
    background: var(--accent);
  }
  .terminal-dots i:nth-child(2) {
    background: var(--accent);
    opacity: 0.45;
  }
  .terminal-dots i:last-child {
    background: var(--border-strong);
  }
  .terminal-title {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--text-3);
  }
  .terminal-body {
    padding: var(--space-4) var(--space-4) var(--space-5);
    overflow-x: auto;
    overflow-y: auto;
    max-height: 380px;
    cursor: text;
  }
  .terminal-body :global(pre) {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    line-height: 1.75;
    color: var(--text-2);
    white-space: pre-wrap;
    word-break: break-word;
  }
  .terminal-body :global(.t-accent) {
    color: var(--accent);
  }
  .terminal-body :global(.t-cursor) {
    display: inline-block;
    width: 0.6em;
    height: 1.1em;
    margin-left: 2px;
    vertical-align: text-bottom;
    background: var(--accent);
    animation: t-blink 1.1s steps(2, start) infinite;
  }
  @keyframes t-blink {
    to {
      visibility: hidden;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .terminal-body :global(.t-cursor) {
      animation: none;
    }
  }

  /* ---- modo interativo (linhas injetadas pelo app.ts não têm scope) ---- */
  .terminal-body :global(.t-out) {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    line-height: 1.75;
    color: var(--text-2);
    white-space: pre-wrap;
    word-break: break-word;
    display: block;
  }
  .terminal-body :global(.t-out .t-line) {
    display: block;
  }
  .terminal-body :global(.t-line.is-live) {
    opacity: 1;
    animation: none;
  }
  .terminal-body :global(.t-cmd) {
    color: var(--text);
    font-weight: 600;
  }
  .terminal-body :global(.t-warn) {
    color: var(--accent);
    opacity: 0.85;
  }
  .terminal-body :global(.t-form) {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
  }
  .terminal-body :global(.t-input) {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: none;
    outline: none;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    caret-color: var(--accent);
    padding: 2px 0;
  }
  .terminal-body :global(.t-input::placeholder) {
    color: var(--text-3);
    opacity: 0.7;
  }
</style>
