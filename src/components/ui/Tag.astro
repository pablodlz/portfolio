---
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<span class:list={['tag', className]}><slot /></span>

<style>
  .tag {
    display: inline-flex;
    align-items: center;
    padding: 2px 10px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--bg-raised-2);
    color: var(--text-2);
    font-size: var(--fs-xs);
    font-weight: 500;
    line-height: 1.7;
    white-space: nowrap;
  }
</style>
