---
import Icon from './Icon.astro';
---

<button
  id="theme-toggle"
  class="theme-toggle"
  type="button"
  aria-pressed="false"
  aria-label="Alternar entre tema escuro e claro"
>
  <Icon name="sun" size={18} class="icon-sun" />
  <Icon name="moon" size={18} class="icon-moon" />
</button>

<style>
  /* v3: toggle na cor de acento */
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-md);
    border: 1px solid var(--accent-border);
    color: var(--accent);
    background: var(--accent-soft);
    cursor: pointer;
    transition:
      color var(--dur-2) var(--ease),
      border-color var(--dur-2) var(--ease),
      background-color var(--dur-2) var(--ease),
      transform var(--dur-1) var(--ease);
  }
  .theme-toggle:hover {
    border-color: var(--accent);
    transform: translateY(-1px) rotate(12deg);
  }

  /* dark mostra o sol (ação: ir p/ claro); light mostra a lua */
  :global(html[data-theme='light']) .theme-toggle :global(.icon-sun) {
    display: none;
  }
  :global(html:not([data-theme='light'])) .theme-toggle :global(.icon-moon) {
    display: none;
  }
  /* sem JS o botão não funciona — escondê-lo */
  :global(html.no-js) .theme-toggle {
    display: none;
  }
</style>
