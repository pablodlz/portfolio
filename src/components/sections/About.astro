---
import { Image } from 'astro:assets';
import { data } from '../../lib/data';
import { withBase } from '../../lib/url';
import SectionHeading from '../ui/SectionHeading.astro';
import Card from '../ui/Card.astro';
import Badge from '../ui/Badge.astro';
import Tag from '../ui/Tag.astro';
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';
import profilePhoto from '../../../img/profile-v3.png';

const { profile, about, recommendationsReceived } = data;
const others = recommendationsReceived.total - recommendationsReceived.highlighted.length;
---

<section id="sobre" class="section">
  <div class="container">
    <SectionHeading
      eyebrow="whoami"
      title="Sobre"
      description="Segurança como ofício e como padrão de qualidade."
    />

    <div class="about-grid">
      <div class="about-text reveal">
        {about.bio.map((p) => (
          <p class="about-bio">{p}</p>
        ))}

        <h3>No dia a dia</h3>
        <ul class="about-daily">
          {about.experiencia.map((item) => (
            <li>{item}</li>
          ))}
        </ul>

        <h3>Stack em uso</h3>
        <ul class="about-pills" aria-label="Principais competências">
          {data.topSkills.map((s) => (
            <li><Tag>{s}</Tag></li>
          ))}
        </ul>
      </div>

      <Card class="about-card reveal" data-ri="1">
        <Image
          src={profilePhoto}
          alt={`Foto de ${profile.fullName}`}
          width={520}
          height={500}
          class="about-photo"
        />
        <div class="about-card-head">
          <p class="about-name">{profile.shortName}</p>
          <p class="about-role">{profile.role}</p>
          <Badge tone="ok" dot>Na ativa @ {profile.company.split(' ')[0]}</Badge>
        </div>
        <ul class="about-facts">
          <li>
            <Icon name="map-pin" size={16} />
            {profile.location}
          </li>
          <li>
            <Icon name="languages" size={16} />
            {profile.languages.map((l) => l.name).join(' · ')}
          </li>
          <li>
            <Icon name="activity" size={16} />
            {profile.followers.toLocaleString('pt-BR')} seguidores no LinkedIn
          </li>
        </ul>
        <ul class="about-soft" aria-label="Competências comportamentais">
          {about.habilidades.map((h) => (
            <li><Tag>{h}</Tag></li>
          ))}
        </ul>
        <Button
          href={withBase(`/${profile.resume}`)}
          variant="cta"
          icon="download"
          download
          class="about-resume"
        >
          Baixar currículo
        </Button>
      </Card>
    </div>

    <div class="about-recs">
      {recommendationsReceived.highlighted.map((rec, i) => (
        <Card as="article" class="rec-card reveal" data-ri={i}>
          <header class="rec-head">
            <span class="rec-avatar" aria-hidden="true">{rec.author.charAt(0)}</span>
            <span class="rec-id">
              <cite class="rec-name">{rec.author}</cite>
              <span class="rec-role">{rec.authorTitle}</span>
            </span>
          </header>
          <blockquote class="rec-quote">
            <p>“{rec.text}”</p>
          </blockquote>
          <button type="button" class="rec-more" aria-expanded="false">Ver recomendação</button>
        </Card>
      ))}

      <a
        class="rec-cta reveal"
        data-ri="2"
        href={`${profile.profileUrl}details/recommendations/`}
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="rec-cta-n">+{others}</span>
        <span class="rec-cta-text">outras recomendações<br />no LinkedIn</span>
        <span class="rec-cta-go">Ver todas <Icon name="arrow-right" size={15} /></span>
      </a>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    gap: var(--space-6);
    align-items: start;
  }
  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
  }

  .about-text {
    display: grid;
    gap: var(--space-4);
  }
  /* v3: tamanho único em todo o bloco de texto (consistência) */
  .about-bio,
  .about-daily {
    font-size: var(--fs-body);
    color: var(--text-2);
  }
  .about-text h3 {
    margin-top: var(--space-3);
  }
  .about-daily {
    display: grid;
    gap: var(--space-3);
    padding-left: 1.1rem;
    list-style: '▸  ';
  }
  .about-daily li::marker {
    color: var(--accent);
  }
  .about-pills,
  .about-soft {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .about-card {
    display: grid;
    gap: var(--space-4);
    justify-items: start;
    align-content: start;
  }
  /* foto grande em destaque (pedido do redesign v2) */
  :global(.about-photo) {
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    max-height: 340px;
    border-radius: var(--radius-lg);
    object-fit: cover;
    object-position: center top;
    border: 1px solid var(--border-strong);
  }
  /* respiro entre tags comportamentais e o CTA do currículo */
  .about-card :global(.about-resume) {
    margin-top: var(--space-4);
  }
  .about-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.3rem;
  }
  .about-role {
    color: var(--text-2);
    font-size: var(--fs-small);
    margin-bottom: var(--space-2);
  }
  .about-facts {
    display: grid;
    gap: var(--space-2);
    color: var(--text-2);
    font-size: var(--fs-small);
  }
  .about-facts li {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .about-facts :global(svg) {
    color: var(--text-3);
    flex: none;
  }

  /* v3: recomendações compactas em 3 colunas (estilo reviews SaaS) */
  .about-recs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
    margin-top: var(--space-7);
    align-items: start;
  }
  @media (max-width: 1000px) {
    .about-recs {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 680px) {
    .about-recs {
      grid-template-columns: 1fr;
    }
  }

  .about-recs :global(.rec-card) {
    padding: var(--space-4);
    display: grid;
    gap: var(--space-3);
    align-content: start;
  }
  .rec-head {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .rec-avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    flex: none;
    border-radius: var(--radius-pill);
    background: var(--accent-soft);
    border: 1px solid var(--accent-border);
    color: var(--accent);
    font-family: var(--font-mono);
    font-weight: 700;
  }
  .rec-id {
    display: grid;
    min-width: 0;
  }
  .rec-name {
    font-style: normal;
    font-weight: 600;
    font-size: var(--fs-small);
  }
  .rec-role {
    color: var(--text-3);
    font-size: var(--fs-xs);
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .rec-quote p {
    color: var(--text-2);
    font-size: var(--fs-small);
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .about-recs :global(.rec-card.is-open) .rec-quote p {
    -webkit-line-clamp: unset;
  }
  .rec-more {
    width: fit-content;
    font-size: var(--fs-xs);
    font-weight: 600;
    color: var(--accent);
    cursor: pointer;
  }
  .rec-more:hover {
    color: var(--accent-hover);
  }

  .rec-cta {
    display: grid;
    align-content: center;
    justify-items: start;
    gap: var(--space-2);
    min-height: 100%;
    padding: var(--space-4);
    border: 1px dashed var(--accent-border);
    border-radius: var(--radius-lg);
    background: var(--accent-soft);
    color: inherit;
    transition: border-color var(--dur-2) var(--ease), transform var(--dur-2) var(--ease);
  }
  .rec-cta:hover {
    text-decoration: none;
    border-color: var(--accent);
    transform: translateY(-2px);
    color: inherit;
  }
  .rec-cta-n {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 600;
    color: var(--accent);
    line-height: 1;
  }
  .rec-cta-text {
    font-size: var(--fs-small);
    color: var(--text-2);
  }
  .rec-cta-go {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    font-weight: 600;
    color: var(--accent);
  }
</style>
