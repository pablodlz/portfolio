---
import { data } from '../../lib/data';
import SectionHeading from '../ui/SectionHeading.astro';
import Card from '../ui/Card.astro';
import Tag from '../ui/Tag.astro';
import Icon from '../ui/Icon.astro';
import type { IconName } from '../../lib/icons';

const { about } = data;

// Números reais derivados dos dados (substitui o antigo "painel ilustrativo").
const firstYear = Math.min(...data.experience.map((e) => Number(e.startDate.slice(0, 4))));
const stats = [
  { count: 50, suffix: '+', label: 'certificações e treinamentos' },
  { count: data.publications.length, suffix: '', label: 'publicações no LinkedIn' },
  { count: data.speaking.length, suffix: '', label: 'palestras e minicursos' },
  { count: new Date().getFullYear() - firstYear, suffix: '+', label: 'anos em tecnologia' },
];

/**
 * Agrupamento determinístico (specs/content-model.md §Agrupamento).
 * Textos literais do JSON; ferramentas extraídas das próprias strings.
 */
interface Domain {
  icon: IconName;
  title: string;
  texts: string[];
  tools: string[];
  wide?: boolean;
}

const domains: Domain[] = [
  {
    icon: 'shield',
    title: 'SOC & Defesa',
    texts: about.experiencia,
    tools: ['Octopus', 'Wazuh', 'Rapid7', 'Jira', 'Playbooks', 'SLA'],
    wide: true,
  },
  {
    icon: 'code',
    title: 'AppSec & DevSecOps',
    texts: [about.conhecimento[0]!, about.conhecimento[1]!],
    tools: ['SAST', 'DAST', 'SCA', 'Horusec', 'Snyk', 'OWASP ZAP', 'GitHub Actions', 'Jenkins', 'Python'],
  },
  {
    icon: 'target',
    title: 'Segurança Ofensiva',
    texts: [about.conhecimento[3]!],
    tools: ['Enumeração', 'Exploração', 'Hardening', 'CTFs', 'Análise de Intrusão'],
  },
  {
    icon: 'layers',
    title: 'Frameworks & Base',
    texts: [about.conhecimento[2]!, about.conhecimento[4]!, about.conhecimento[5]!],
    tools: ['OWASP Top 10', 'SAMM', 'ASVS', 'NIST', 'MITRE ATT&CK', 'Redes', 'Linux', 'ML'],
  },
];
---

<section id="skills" class="section skills">
  <div class="container">
    <SectionHeading
      eyebrow="capabilities"
      title="Capacidades"
      description="Quatro domínios, um objetivo: reduzir risco de ponta a ponta."
    />

    <div class="skills-bento">
      {domains.map((d, i) => (
        <Card as="article" class={`skill-card${d.wide ? ' skill-card--wide' : ''} reveal`} data-ri={i}>
          <div class="skill-head">
            <span class="skill-icon"><Icon name={d.icon} size={22} /></span>
            <h3>{d.title}</h3>
          </div>
          <ul class="skill-texts">
            {d.texts.map((t) => (
              <li>{t}</li>
            ))}
          </ul>
          <ul class="skill-tools" aria-label={`Ferramentas de ${d.title}`}>
            {d.tools.map((t) => (
              <li><Tag>{t}</Tag></li>
            ))}
          </ul>
        </Card>
      ))}

      <Card class="skill-stats reveal" data-ri="4">
        <ul class="stats-grid">
          {stats.map((s) => (
            <li>
              <span class="stat-n">
                <span data-count={s.count}>0</span>{s.suffix && <span class="stat-plus">{s.suffix}</span>}
              </span>
              <span class="stat-label">{s.label}</span>
            </li>
          ))}
        </ul>
      </Card>
    </div>
  </div>
</section>

<style>
  .skills {
    background: var(--bg-raised);
    border-block: 1px solid var(--border);
  }
  /* cards da seção assentam no fundo base para criar contraste */
  .skills :global(.card) {
    background: var(--bg);
  }

  .skills-bento {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }
  .skills :global(.skill-card--wide) {
    grid-column: span 2;
  }
  @media (max-width: 1100px) {
    .skills-bento {
      grid-template-columns: 1fr 1fr;
    }
    .skills :global(.skill-card--wide) {
      grid-column: span 2;
    }
  }
  @media (max-width: 720px) {
    .skills-bento {
      grid-template-columns: 1fr;
    }
    .skills :global(.skill-card--wide) {
      grid-column: auto;
    }
  }

  .skill-head {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }
  .skill-icon {
    display: inline-flex;
    padding: 9px;
    border-radius: var(--radius-md);
    background: var(--accent-soft);
    color: var(--accent);
    border: 1px solid var(--accent-border);
  }
  .skill-texts {
    display: grid;
    gap: var(--space-3);
    color: var(--text-2);
    font-size: var(--fs-small);
    margin-bottom: var(--space-4);
  }
  .skill-tools {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  /* card de números reais (Zento) com contadores animados */
  .skills-bento :global(.skill-stats) {
    display: grid;
    align-content: center;
  }
  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5) var(--space-4);
  }
  .stats-grid li {
    display: grid;
    gap: 2px;
  }
  .stat-n {
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.02em;
  }
  .stat-plus {
    color: var(--accent);
  }
  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-3);
    letter-spacing: 0.02em;
  }
</style>
