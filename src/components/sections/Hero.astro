---
import { data, obfuscatedEmail } from '../../lib/data';
import { withBase } from '../../lib/url';
import { formatRange } from '../../lib/dates';
import Button from '../ui/Button.astro';
import Badge from '../ui/Badge.astro';
import Terminal from '../ui/Terminal.astro';

const { profile, about } = data;
// Subtítulo: headline + primeira frase do summary (recorte, não invenção).
const firstSentence = about.summary.split('. ')[0] + '.';
const [firstName, ...restName] = profile.fullName.split(' ');

// Linhas de "boot" do terminal (easter egg do LinkedIn); o shell interativo
// entra logo abaixo delas (app.ts).
const termLines = about.easterEgg.content.map((line, i) => ({
  text: line === '' ? ' ' : line,
  accent: line.startsWith('┌') || line.startsWith('└'),
  i,
}));

// Dados reais p/ os comandos do terminal (via atributo — escapado pelo Astro).
const termData = {
  name: profile.fullName,
  role: profile.role,
  company: profile.company.split(' ')[0],
  headline: profile.headline,
  location: profile.location,
  bio: about.bio[0],
  github: profile.contact.github,
  ghUser: profile.contact.githubUser,
  linkedin: profile.contact.linkedin,
  socials: profile.socials.map((s) => ({ name: s.name, url: s.url })),
  skills: data.topSkills,
  experience: data.experience.map((e) => ({
    title: e.title,
    org: e.company,
    range: formatRange(e.startDate, e.endDate, e.current),
  })),
  education: data.education.map((e) => ({
    degree: e.degree,
    field: e.field,
    org: e.institution,
    years: `${e.startYear}–${e.endYear}`,
  })),
  projects: data.projects.map((p) => ({ name: p.name, cat: p.category })),
  certs: data.certifications.displayTotal,
  certDocs: data.certifications.downloadedDocuments.files.length,
  pubs: data.publications.length,
  talks: data.speaking.length,
  resume: withBase(`/${profile.resume}`),
  mail: obfuscatedEmail(),
};
---

<section id="top" class="hero atmosphere">
  <canvas class="particles" aria-hidden="true"></canvas>
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="reveal" data-ri="0">
        <Badge tone="ok" dot pulse>SOC ANALYST @ CLAVIS — NA ATIVA</Badge>
      </p>

      <!-- h1 e subtítulo SEM reveal: são o LCP — precisam pintar no 1º paint -->
      <h1>
        <span class="text-gradient">{firstName}</span><br />
        <span class="text-accent">{restName.join(' ')}</span>
      </h1>

      <p class="hero-sub">
        {firstSentence}
      </p>

      <p class="hero-headline reveal" data-ri="1">{profile.headline}</p>

      <div class="hero-ctas reveal" data-ri="2">
        <Button href={withBase(`/${profile.resume}`)} variant="cta" icon="download" download>
          Baixar currículo
        </Button>
        <Button href="#contato" variant="secondary" icon="mail">Contato</Button>
        <Button href={profile.contact.github} variant="secondary" icon="github" external>
          GitHub
        </Button>
        <Button href={profile.contact.linkedin} variant="secondary" icon="linkedin" external>
          LinkedIn
        </Button>
      </div>
    </div>

    <div class="hero-terminal reveal" data-ri="3">
      <Terminal title="root@kali: ~/pablodlz" ariaLabel="Terminal interativo com easter egg" spotlight>
        <pre>{termLines.map((l) => <span class={l.accent ? 't-line t-accent' : 't-line'} data-ri={l.i}>{l.text}</span>)}</pre>
        <pre class="t-out" role="log" aria-live="polite"></pre>
        <form class="t-form" data-term={JSON.stringify(termData)}>
          <label class="visually-hidden" for="term-input">
            Terminal interativo — digite um comando e pressione Enter. Dica: help
          </label>
          <span class="t-accent" aria-hidden="true">&#10095;</span>
          <span class="t-input-wrap">
            <input
              id="term-input"
              class="t-input"
              type="text"
              autocomplete="off"
              autocapitalize="off"
              spellcheck="false"
              placeholder="digite help e pressione Enter"
            />
            <span class="t-ghost" aria-hidden="true" hidden>
              <span class="t-ghost-text"></span>
              <span class="t-ghost-cursor"></span>
            </span>
          </span>
        </form>
      </Terminal>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: clamp(4rem, 9vw, 7rem) var(--section-pad);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
    gap: var(--space-8);
    align-items: center;
  }
  @media (max-width: 960px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: var(--space-7);
    }
  }

  .hero-copy {
    display: grid;
    gap: var(--space-5);
    justify-items: start;
  }
  .hero-sub {
    font-size: var(--fs-body-lg);
    color: var(--text-2);
    max-width: 34rem;
  }
  .hero-headline {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--text-3);
    letter-spacing: 0.02em;
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  /* linhas do terminal "digitam" em cascata */
  .t-line {
    display: block;
    opacity: 0;
    animation: t-line-in 300ms var(--ease) forwards;
    animation-delay: calc(400ms + var(--t-index, 0) * 140ms);
  }
  @keyframes t-line-in {
    to {
      opacity: 1;
    }
  }
  html.no-js .t-line {
    opacity: 1;
    animation: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .t-line {
      opacity: 1;
      animation: none;
    }
  }
</style>
